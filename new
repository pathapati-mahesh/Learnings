import numpy as np
import pandas as pd
from typing import List, Dict, Any

from langchain.chains import LLMChain
from sklearn.mixture import GaussianMixture
from langchain_openai import OpenAIEmbeddings
from langchain_community.vectorstores import FAISS
from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate
from langchain.retrievers import ContextualCompressionRetriever
from langchain.retrievers.document_compressors import LLMChainExtractor
from langchain_core.messages import AIMessage
from langchain_core.documents import Document
from langchain_community.document_loaders import PyPDFLoader
import logging
import os
from dotenv import load_dotenv

load_dotenv()
os.environ["OPENAI_API_KEY"] = os.getenv('OPENAI_API_KEY')
logging.basicConfig(level=logging.INFO, format="%(levelname)s | %(message)s")


# ── helpers ────────────────────────────────────────────────────────────────

def extract_text(item):
    if isinstance(item, AIMessage):
        return item.content
    return item


def embed_texts(texts: List[str]) -> List[List[float]]:
    logging.info(f"Embedding {len(texts)} texts")
    return OpenAIEmbeddings().embed_documents([extract_text(t) for t in texts])


def perform_clustering(embeddings: np.ndarray, n_clusters: int = 10) -> np.ndarray:
    n_clusters = max(2, min(n_clusters, len(embeddings) - 1))
    logging.info(f"Clustering into {n_clusters} groups")
    return GaussianMixture(n_components=n_clusters, random_state=42).fit_predict(embeddings)


def summarize_texts(texts: List[str], llm: ChatOpenAI) -> str:
    logging.info(f"Summarising {len(texts)} texts")
    prompt = ChatPromptTemplate.from_template(
        "Summarize the following text concisely:\n\n{text}"
    )
    return extract_text((prompt | llm).invoke({"text": "\n\n".join(texts)}))


def build_vectorstore(tree_results: Dict[int, pd.DataFrame], embeddings) -> FAISS:
    docs = []
    for level, df in tree_results.items():
        for _, row in df.iterrows():
            meta = dict(row["metadata"])
            meta["raptor_level"] = level
            docs.append(Document(page_content=str(row["text"]), metadata=meta))
    logging.info(f"Building FAISS with {len(docs)} documents")
    return FAISS.from_documents(docs, embeddings)


def create_retriever(vectorstore: FAISS, llm: ChatOpenAI) -> ContextualCompressionRetriever:
    base = vectorstore.as_retriever()
    prompt = ChatPromptTemplate.from_template(
        "Given the following context and question, extract only the relevant information:\n\n"
        "Context: {context}\n"
        "Question: {question}\n\n"
        "Relevant Information:"
    )
    return ContextualCompressionRetriever(
        base_compressor=LLMChainExtractor.from_llm(llm, prompt=prompt),
        base_retriever=base,
    )


def find_exact_pages(
    query: str,
    retrieved_docs,
    tree_results,
    embeddings,
):
    """
    Return only the exact page(s) where the answer actually lives.

    Leaf nodes (raptor_level 0) have one page — use it directly.
    Summary nodes (raptor_level >= 1) carry a large pages list — re-rank
    those candidate leaf pages by cosine similarity to the query and keep
    only the best match.
    """
    exact_pages = set()

    # page -> leaf text from level-0
    leaf_df = tree_results.get(0, __import__("pandas").DataFrame())
    page_to_text = {}
    if not leaf_df.empty:
        for _, row in leaf_df.iterrows():
            p = row["metadata"].get("page")
            if p is not None:
                page_to_text[int(p)] = str(row["text"])

    query_emb = __import__("numpy").array(embeddings.embed_query(query))

    for doc in retrieved_docs:
        m     = doc.metadata
        level = m.get("raptor_level", 0)

        if level == 0:
            p = m.get("page")
            if p is not None:
                exact_pages.add(int(p) + 1)   # 0-based -> 1-based
        else:
            candidates = [int(p) for p in (m.get("pages") or []) if p is not None]
            if not candidates:
                continue
            best_score, best_page = -1.0, None
            for p in candidates:
                leaf_text = page_to_text.get(p)
                if not leaf_text:
                    continue
                import numpy as _np
                leaf_emb = _np.array(embeddings.embed_query(leaf_text))
                score = float(
                    _np.dot(query_emb, leaf_emb)
                    / (_np.linalg.norm(query_emb) * _np.linalg.norm(leaf_emb) + 1e-9)
                )
                if score > best_score:
                    best_score, best_page = score, p
            if best_page is not None:
                exact_pages.add(best_page + 1)   # 0-based -> 1-based

    return sorted(exact_pages)



# ── main class ─────────────────────────────────────────────────────────────

class RAPTORMethod:
    def __init__(self, texts: List[str], metadatas: List[Dict], max_levels: int = 3):
        """
        Parameters
        ----------
        texts     : page texts from PyPDFLoader
        metadatas : page metadatas from PyPDFLoader  — MUST include {"page": int}
        """
        self.texts      = texts
        self.metadatas  = metadatas
        self.max_levels = max_levels
        self.embeddings = OpenAIEmbeddings()
        self.llm        = ChatOpenAI(model_name="gpt-4o-mini")
        self.tree_results = self._build_raptor_tree()

    def _build_raptor_tree(self) -> Dict[int, pd.DataFrame]:
        results = {}

        # ── Level 0 seed: raw pages with their page numbers ────────────
        current_texts = [extract_text(t) for t in self.texts]
        current_meta  = [
            {
                "level":   0,
                "origin":  "original",
                "page":    m.get("page"),           # 0-based from PyPDFLoader
                "pages":   [m.get("page")],          # aggregated list (same value at L0)
                "source":  m.get("source", ""),
            }
            for m in self.metadatas
        ]

        for level in range(1, self.max_levels + 1):
            logging.info(f"── RAPTOR level {level} ──")

            embs   = embed_texts(current_texts)
            k      = min(10, len(current_texts) // 2)
            labels = perform_clustering(np.array(embs), k)

            df = pd.DataFrame({
                "text":      current_texts,
                "embedding": embs,
                "cluster":   labels,
                "metadata":  current_meta,
            })
            results[level - 1] = df

            # ── summarise each cluster, propagate page numbers up ──────
            next_texts = []
            next_meta  = []

            for cluster_id in sorted(df["cluster"].unique()):
                rows   = df[df["cluster"] == cluster_id]
                ctexts = rows["text"].tolist()
                cmetas = rows["metadata"].tolist()

                summary = summarize_texts(ctexts, self.llm)

                # collect ALL page numbers that fed into this summary
                all_pages = []
                for m in cmetas:
                    all_pages.extend(m.get("pages") or [])
                # deduplicate and sort
                all_pages = sorted(set(p for p in all_pages if p is not None))

                next_texts.append(summary)
                next_meta.append({
                    "level":  level,
                    "origin": f"summary_cluster_{cluster_id}_level_{level - 1}",
                    "page":   None,          # summary nodes have no single page
                    "pages":  all_pages,     # but they carry ALL source pages
                    "id":     f"summary_{level}_{cluster_id}",
                })

            current_texts = next_texts
            current_meta  = next_meta

            if len(current_texts) <= 1:
                results[level] = pd.DataFrame({
                    "text":      current_texts,
                    "embedding": embed_texts(current_texts),
                    "cluster":   [0],
                    "metadata":  current_meta,
                })
                logging.info(f"Tree complete at level {level}")
                break

        return results

    def run(self, query: str, k: int = 6) -> Dict[str, Any]:
        vectorstore   = build_vectorstore(self.tree_results, self.embeddings)
        retriever     = create_retriever(vectorstore, self.llm)

        logging.info(f"Query: {query}")

        # similarity scores before compression changes text
        hits      = vectorstore.similarity_search_with_relevance_scores(query, k=k)
        score_map = {doc.page_content: round(score, 4) for doc, score in hits}

        relevant_docs = retriever.get_relevant_documents(query)

        # ── exact page(s) where the answer actually lives ─────────────
        source_pages = find_exact_pages(
            query, relevant_docs, self.tree_results, self.embeddings
        )

        # ── answer ─────────────────────────────────────────────────────
        context = "\n\n".join(d.page_content for d in relevant_docs)

        # ask the LLM: if the answer is not in context, say so explicitly
        prompt = ChatPromptTemplate.from_template(
            "Answer the question using ONLY the context below.\n"
            "If the answer is not present in the context, reply with exactly: "
            "\"Content not found in document.\"\n\n"
            "Context:\n{context}\n\n"
            "Question: {question}\n\n"
            "Answer:"
        )
        chain  = LLMChain(llm=self.llm, prompt=prompt)
        answer = chain.run(context=context, question=query).strip()

        # if the LLM said content not found, clear the page numbers too
        not_found = "content not found" in answer.lower()
        if not_found:
            source_pages = []

        # ── similarity scores per retrieved doc ───────────────────────
        scores = []
        for doc in relevant_docs:
            score = score_map.get(doc.page_content)
            if score is None:
                # compression rewrote the text — match by metadata instead
                for orig_doc, orig_score in hits:
                    if orig_doc.metadata == doc.metadata:
                        score = round(orig_score, 4)
                        break
            scores.append({
                "score":      score,
                "page":       (int(doc.metadata["page"]) + 1)
                              if doc.metadata.get("page") is not None
                              else None,
                "pages":      doc.metadata.get("pages"),
                "raptor_level": doc.metadata.get("raptor_level"),
            })

        scores.sort(key=lambda x: x["score"] or 0, reverse=True)

        return {
            "query":            query,
            "answer":           answer,
            "page_numbers":     source_pages,   # [] when answer not in document
            "similarity_scores": scores,
            "model_used":       self.llm.model_name,
        }


# ── CLI ────────────────────────────────────────────────────────────────────

def parse_args():
    import argparse
    parser = argparse.ArgumentParser(description="Run RAPTORMethod")
    parser.add_argument("--path",       type=str, required=True,
                        help="Path to the PDF file.")
    parser.add_argument("--query",      type=str, default="What is the main topic?")
    parser.add_argument("--max_levels", type=int, default=3)
    return parser.parse_args()


if __name__ == "__main__":
    args = parse_args()

    loader    = PyPDFLoader(args.path)
    documents = loader.load()

    texts     = [doc.page_content for doc in documents]
    metadatas = [doc.metadata     for doc in documents]

    raptor = RAPTORMethod(texts, metadatas, max_levels=args.max_levels)
    result = raptor.run(args.query)

    print(f"\nQuery   : {result['query']}")
    print(f"Answer  : {result['answer']}")
    if result["page_numbers"]:
        print(f"Pages   : {result['page_numbers']}")
    else:
        print("Pages   : Content not found in document.")
    print("\nSimilarity scores:")
    for s in result["similarity_scores"]:
        page_info = f"p.{s['page']}" if s["page"] else f"pages {s['pages']}"
        print(f"  [{s['score']:.4f}]  L{s['raptor_level']}  {page_info}")
